generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum order_status {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum payment_provider {
  STRIPE
  MPESA
  PAYPAL
}

enum payment_status {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum shipment_status {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum discount_type {
  PERCENTAGE
  FIXED
}


model users {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password_hash    String
  created_at       DateTime  @default(now())
  deleted_at       DateTime?

  carts            carts?
  orders           orders[]
  user_roles       user_roles[]
  user_permissions user_permissions[]
  vendors          vendors?
  audit_logs       audit_logs[]
  refreshTokens    refresh_tokens[]

  @@index([email])
  @@index([name])
  @@index([deleted_at])
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  expires_at DateTime
  created_at DateTime @default(now())
}


model roles {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  description      String?
  created_at       DateTime @default(now())

  user_roles       user_roles[]
  role_permissions role_permissions[]

  @@index([name])
}


model permissions {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  description      String?
  created_at       DateTime @default(now())

  user_permissions user_permissions[]
  role_permissions role_permissions[]

  @@index([name])
}


model user_roles {
  user_id Int
  role_id Int

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  roles roles @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
}


model user_permissions {
  user_id       Int
  permission_id Int

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  permissions permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([user_id, permission_id])
}


model role_permissions {
  role_id       Int
  permission_id Int

  roles roles @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permissions permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}


model vendors {
  id            Int       @id @default(autoincrement())
  user_id       Int       @unique
  business_name String?
  description   String?
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  discounts discounts[]

  @@index([user_id])
  @@index([business_name])
  @@index([deleted_at])
}


model categories {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  products      products[]
  subcategories subcategories[]

  @@index([name])
  @@index([deleted_at])
}


model subcategories {
  id          Int      @id @default(autoincrement())
  name        String
  category_id Int?
  created_at  DateTime @default(now())
  deleted_at  DateTime?

  categories categories? @relation(fields: [category_id], references: [id], onDelete: Cascade)
  products   products[]

  @@unique([name, category_id])
  @@index([category_id])
}


model products {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  price          Decimal  @db.Decimal(10,2)
  stock          Int      @default(0)
  category_id    Int
  subcategory_id Int?
  created_at     DateTime @default(now())
  deleted_at     DateTime?

  categories      categories @relation(fields: [category_id], references: [id], onDelete: Restrict)
  subcategories  subcategories? @relation(fields: [subcategory_id], references: [id], onDelete: Restrict)

  cart_items     cart_items[]
  order_items    order_items[]
  product_images product_images[]
  discounts      discounts[]

  @@index([name])
  @@index([price])
  @@index([stock])
  @@index([category_id])
  @@index([subcategory_id])
  @@index([deleted_at])
}


model discounts {
  id         Int      @id @default(autoincrement())
  product_id Int
  vendor_id  Int
  code       String?
  discount_type       discount_type
  value      Decimal  @db.Decimal(10,2)
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  vendors  vendors  @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([vendor_id])
  @@index([is_active, start_date, end_date])
}


model carts {
  id         Int      @id @default(autoincrement())
  user_id    Int?     @unique
  session_id String?  @unique
  created_at DateTime @default(now())
  deleted_at DateTime?

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  cart_items cart_items[]

  @@index([user_id])
  @@index([session_id])
  @@index([deleted_at])
}


model cart_items {
  id         Int      @id @default(autoincrement())
  cart_id    Int
  product_id Int
  quantity   Int
  created_at DateTime @default(now())
  deleted_at DateTime?

  carts    carts    @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, product_id])
}


model orders {
  id               Int           @id @default(autoincrement())
  user_id          Int?
  total            Decimal       @db.Decimal(10,2)
  status           order_status  @default(PENDING)
  shipping_address String?
  phone            String?
  customer_name    String?
  customer_email   String?
  created_at       DateTime      @default(now())
  deleted_at       DateTime?

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  order_items order_items[]
  payments     payments[]
  shipments    shipments[]

  @@index([user_id])
  @@index([status])
}


model order_items {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  price      Decimal @db.Decimal(10,2)
  created_at DateTime @default(now())
  deleted_at DateTime?

  orders   orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([product_id])
}


model payments {
  id              Int              @id @default(autoincrement())
  order_id        Int
  provider        payment_provider
  amount          Decimal @db.Decimal(10,2)
  status          payment_status @default(PENDING)
  transaction_ref String @unique
  attempt_count   Int @default(1)
  created_at      DateTime @default(now())

  orders orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([status])
}


model shipments {
  id              Int     @id @default(autoincrement())
  order_id        Int
  address         String
  city            String
  phone           String
  status shipment_status @default(PENDING)
  tracking_number String @unique
  created_at      DateTime @default(now())

  orders orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([status])
}


model product_images {
  id         Int     @id @default(autoincrement())
  product_id Int
  image_url  String
  is_main    Boolean @default(false)
  position   Int @default(0)
  created_at DateTime @default(now())
  deleted_at DateTime?

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}


model audit_logs {
  id         Int      @id @default(autoincrement())
  table_name String
  record_id  Int
  action     String

  changed_by Int?
  users users? @relation(fields: [changed_by], references: [id])

  session_id String?

  changed_at DateTime @default(now())
  old_data   Json?
  new_data   Json?

  @@index([table_name, record_id])
  @@index([changed_by])
  @@index([session_id])
}